<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title><%= assigns[:page_title] || "SimpleChat" %></title>

    <%= if vite_dev?() do %>
      <script type="module" src="<%= vite_client_path() %>"></script>
    <% end %>
    <%= for css_path <- vite_stylesheet_paths("js/app.js") do %>
      <link rel="stylesheet" href="<%= css_path %>"/>
    <% end %>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&display=swap" rel="stylesheet">

    <%= csrf_meta_tag() %>
  </head>
  <body>
    <div class="node-info">
        <p><%= assigns[:node] %></p>
    </div>

    <%= @inner_content %>

    <script>
            window.userId="<%= assigns[:id] %>";
            window.authToken="<%= assigns[:auth_token] %>";
    </script>

    <script type="module" src="<%= vite_javascript_path("js/app.js") %>"></script>
  </body>
</html>
